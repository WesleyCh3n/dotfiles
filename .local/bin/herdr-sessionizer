#!/usr/bin/env zsh

if [[ $# -eq 1 ]]; then
    selected=$1
else
    selected=$(find ~ ~/GitHub ~/Documents -mindepth 1 -maxdepth 1 -type d | fzf)
fi

if [[ -z $selected ]]; then
    exit 0
fi

label=$(basename "$selected")

# focus existing workspace with this label, else create one
id=$(herdr workspace list | jq -r --arg l "$label" \
    '.result.workspaces[] | select(.label == $l) | .workspace_id' | head -1)

if [[ -n $id ]]; then
    herdr workspace focus "$id"
else
    herdr workspace create --cwd "$selected" --label "$label" --focus
fi
